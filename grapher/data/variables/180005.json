#.YYf3EdnMK_0.\n\nWe have calculated per capita metrics by combining this data with population data from the UN World Population Prospects: https://population.un.org/wpp/\n\n"}}},"entityKey":{"1":{"name":"United Kingdom","code":"GBR"},"2":{"name":"Ireland","code":"IRL"},"3":{"name":"France","code":"FRA"},"4":{"name":"Belgium","code":"BEL"},"5":{"name":"Netherlands","code":"NLD"},"6":{"name":"Germany","code":"DEU"},"7":{"name":"Switzerland","code":"CHE"},"8":{"name":"Italy","code":"ITA"},"9":{"name":"Spain","code":"ESP"},"10":{"name":"Sweden","code":"SWE"},"11":{"name":"Poland","code":"POL"},"12":{"name":"Russia","code":"RUS"},"13":{"name":"United States","code":"USA"},"14":{"name":"Japan","code":"JPN"},"23":{"name":"Australia","code":"AUS"},"24":{"name":"Austria","code":"AUT"},"37":{"name":"Brazil","code":"BRA"},"39":{"name":"Bulgaria","code":"BGR"},"44":{"name":"Canada","code":"CAN"},"70":{"name":"Turkey","code":"TUR"},"81":{"name":"South Africa","code":"ZAF"},"83":{"name":"Slovenia","code":"SVN"},"85":{"name":"Slovakia","code":"SVK"},"92":{"name":"Romania","code":"ROU"},"95":{"name":"Portugal","code":"PRT"},"102":{"name":"Norway","code":"NOR"},"113":{"name":"Mexico","code":"MEX"},"119":{"name":"Lithuania","code":"LTU"},"122":{"name":"Latvia","code":"LVA"},"127":{"name":"South Korea","code":"KOR"},"136":{"name":"Indonesia","code":"IDN"},"137":{"name":"India","code":"IND"},"138":{"name":"Hungary","code":"HUN"},"149":{"name":"Greece","code":"GRC"},"155":{"name":"Finland","code":"FIN"},"156":{"name":"Estonia","code":"EST"},"161":{"name":"Denmark","code":"DNK"},"162":{"name":"Czechia","code":"CZE"},"163":{"name":"Cyprus","code":"CYP"},"165":{"name":"Croatia","code":"HRV"},"171":{"name":"China","code":"CHN"},"198":{"name":"Taiwan","code":"TWN"},"210":{"name":"Luxembourg","code":"LUX"},"212":{"name":"Malta","code":"MLT"}}}